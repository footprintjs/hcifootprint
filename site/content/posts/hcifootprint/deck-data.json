{"deckCss":"\n  *{box-sizing:border-box}\n  html,body{margin:0;padding:0;background:#0a0a0b}\n  :root{\n    --bg:#0a0a0b;--surface:#141416;--surf2:#1c1c1f;--text:#fafafa;--muted:#a1a1a1;--faint:#6b6b6b;\n    --line:rgba(250,250,250,.10);--line2:rgba(250,250,250,.18);\n    --yellow:#ffc700;--yellow-ink:#ffdf7a;\n    --app:#3b82f6;--graph:#ffc700;--mcp:#10b981;--host:#8b5cf6;--agent:#f97316;--danger:#f2545b;\n    --sans:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;\n    --mono:ui-monospace,SFMono-Regular,Menlo,Consolas,'Liberation Mono',monospace;\n  }\n  @keyframes fpDelta{from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:none}}\n  @keyframes fpPanel{from{opacity:0;transform:translateX(54px)}to{opacity:1;transform:none}}\n  @keyframes fpPop{from{opacity:0;transform:scale(.66)}to{opacity:1;transform:scale(1)}}\n  @keyframes fpFoot{from{opacity:0;transform:translateY(-16px) scale(.25)}to{opacity:1;transform:translateY(0) scale(1)}}\n  @keyframes fpFade{from{opacity:0}to{opacity:1}}\n  @keyframes fpChip{from{opacity:0;transform:translateX(-24px)}to{opacity:1;transform:none}}\n  @media (prefers-reduced-motion: no-preference){\n    [data-deck-active] .fp-enter{animation:fpDelta .64s cubic-bezier(.2,.8,.2,1) both}\n    [data-deck-active] .fp-panel{animation:fpPanel .62s cubic-bezier(.2,.8,.2,1) both}\n    [data-deck-active] .fp-pop{animation:fpPop .54s cubic-bezier(.2,1.25,.4,1) both}\n    [data-deck-active] .fp-foot{animation:fpFoot .5s cubic-bezier(.2,1.2,.4,1) both}\n    [data-deck-active] .fp-fade{animation:fpFade .7s ease both}\n    [data-deck-active] .fp-chip{animation:fpChip .52s cubic-bezier(.2,.9,.3,1) both}\n  }\n  [data-motion=\"off\"] .fp-enter,[data-motion=\"off\"] .fp-panel,[data-motion=\"off\"] .fp-pop,\n  [data-motion=\"off\"] .fp-foot,[data-motion=\"off\"] .fp-fade,[data-motion=\"off\"] .fp-chip{\n    animation:none !important;opacity:1 !important;transform:none !important}\n","sections":[{"label":"Title","html":"<section data-label=\"Title\" style=\"background:var(--bg);color:var(--text);width:1920px;height:1080px;box-sizing:border-box;display:flex;flex-direction:column;justify-content:center;padding:0 190px;font-family:var(--sans);align-items:center;text-align:center\"><p style=\"font-family:var(--mono);font-size:29px;letter-spacing:.2em;text-transform:uppercase;color:var(--yellow);margin:0 0 34px\">A footprintjs library</p><h1 style=\"font-size:184px;font-weight:700;letter-spacing:-.04em;margin:0;line-height:1\">H<span style=\"color:var(--yellow)\">A</span>CI&nbsp;<span style=\"color:var(--muted);font-weight:600\">Footprint</span></h1><p style=\"font-size:46px;color:var(--muted);margin:30px 0 0\">Human <b style=\"color:var(--text)\">&amp;</b> Agent · Computer Interaction</p><p style=\"font-size:38px;color:var(--text);margin:46px 0 0;max-width:30ch;line-height:1.35\">Turn your web app into an <b style=\"color:var(--yellow)\">agentic app</b> — an AI drives the frontend a human already can.</p><p style=\"font-family:var(--mono);font-size:32px;color:var(--muted);margin-top:80px\">Read&nbsp;·&nbsp;Scroll&nbsp;·&nbsp;Watch</p></section>"},{"label":"What","html":"<section data-label=\"What\" style=\"background:var(--bg);color:var(--text);width:1920px;height:1080px;box-sizing:border-box;display:flex;flex-direction:column;justify-content:center;padding:0 190px;font-family:var(--sans)\"><p style=\"font-family:var(--mono);font-size:29px;letter-spacing:.2em;text-transform:uppercase;color:var(--yellow);margin:0 0 34px\">What it is</p><h2 style=\"font-size:104px;font-weight:700;letter-spacing:-.03em;line-height:1.03;margin:0\">A skill graph<br>your agent can operate.</h2><p style=\"font-size:44px;color:var(--muted);margin:52px 0 0;max-width:30ch;line-height:1.4\">Describe the app’s interaction surface <b style=\"color:var(--text)\">once</b> — pages, containers, actions. The agent gets a typed, traversable map with a <b style=\"color:var(--yellow)\">you-are-here</b> pin, instead of re-reading a 100k-token DOM every visit.</p><div class=\"fp-chip\" style=\"margin-top:54px;display:inline-flex;align-self:flex-start;font-family:var(--mono);font-size:30px;color:var(--muted);border:1px solid var(--line2);border-radius:14px;padding:20px 30px;background:var(--surface)\">buildNavigationGraph(<span style=\"color:var(--yellow-ink)\">'shop'</span>, { pages, skills })</div></section>"},{"label":"Why","html":"<section data-label=\"Why\" style=\"background:var(--bg);color:var(--text);width:1920px;height:1080px;box-sizing:border-box;display:flex;flex-direction:column;justify-content:center;padding:0 190px;font-family:var(--sans)\"><p style=\"font-family:var(--mono);font-size:29px;letter-spacing:.2em;text-transform:uppercase;color:var(--yellow);margin:0 0 34px\">Why — the problem</p><h2 style=\"font-size:92px;font-weight:700;letter-spacing:-.03em;line-height:1.04;margin:0 0 66px\">Agents driving UIs are<br>blind and brittle.</h2><div style=\"display:flex;gap:44px\"><div style=\"flex:1;border:2px solid var(--line2);border-radius:26px;padding:48px;background:var(--surface)\"><div style=\"font-family:var(--mono);font-size:26px;letter-spacing:.12em;text-transform:uppercase;color:var(--danger)\">Today</div><div style=\"font-size:52px;font-weight:700;margin:20px 0 14px\">Screenshot &amp; DOM guessing</div><div style=\"font-size:30px;color:var(--muted);line-height:1.4\">Re-read the page every turn. Hope the right button is found. Prompt-inject on any product name.</div></div><div style=\"flex:1;border:2px solid var(--yellow);border-radius:26px;padding:48px;background:color-mix(in srgb, var(--yellow) 10%, transparent)\"><div style=\"font-family:var(--mono);font-size:26px;letter-spacing:.12em;text-transform:uppercase;color:var(--yellow)\">HACI Footprint</div><div style=\"font-size:52px;font-weight:700;margin:20px 0 14px\">A typed interaction contract</div><div style=\"font-size:30px;color:var(--muted);line-height:1.4\">One canonical, self-explaining record. It only ever offers what’s doable at the cursor — the footprintjs idea, applied to the frontend.</div></div></div></section>"},{"label":"Gap 1","html":"<section data-label=\"Gap 1\" style=\"background:var(--bg);color:var(--text);width:1920px;height:1080px;box-sizing:border-box;display:flex;flex-direction:column;justify-content:center;padding:0 190px;font-family:var(--sans)\"><p style=\"font-family:var(--mono);font-size:29px;letter-spacing:.2em;text-transform:uppercase;color:var(--yellow);margin:0 0 34px\">The gap loop — the point of the thing</p><h2 style=\"font-size:78px;font-weight:700;letter-spacing:-.02em;line-height:1.05;margin:0 0 60px\">When no skill serves the ask, that’s the signal.</h2><div style=\"display:flex;gap:0;align-items:stretch\"><div class=\"fp-enter\" style=\"flex:1;border:2px solid var(--line2);border-left:6px solid var(--danger);border-radius:22px;padding:40px 38px;background:var(--surface)\"><div style=\"font-family:var(--mono);font-size:24px;letter-spacing:.14em;text-transform:uppercase;color:var(--danger)\">The ask</div><div style=\"font-size:44px;font-weight:700;margin:20px 0 16px;line-height:1.1\">A user asks something the UI can’t serve</div><div style=\"font-size:29px;color:var(--muted);line-height:1.42\">“Why did <b>my</b> order fail?” — the reason is in the backend logs, not on any button. No skill fires.</div></div><div></div><div style=\"flex:1\"></div><div></div><div style=\"flex:1\"></div></div><div style=\"text-align:center\"><div style=\"min-height:82px;margin-top:52px\"></div></div></section>"},{"label":"Gap 2","html":"<section data-label=\"Gap 2\" style=\"background:var(--bg);color:var(--text);width:1920px;height:1080px;box-sizing:border-box;display:flex;flex-direction:column;justify-content:center;padding:0 190px;font-family:var(--sans)\"><p style=\"font-family:var(--mono);font-size:29px;letter-spacing:.2em;text-transform:uppercase;color:var(--yellow);margin:0 0 34px\">The gap loop — the point of the thing</p><h2 style=\"font-size:78px;font-weight:700;letter-spacing:-.02em;line-height:1.05;margin:0 0 60px\">When no skill serves the ask, that’s the signal.</h2><div style=\"display:flex;gap:0;align-items:stretch\"><div class=\"fp-enter\" style=\"flex:1;border:2px solid var(--line2);border-left:6px solid var(--danger);border-radius:22px;padding:40px 38px;background:var(--surface)\"><div style=\"font-family:var(--mono);font-size:24px;letter-spacing:.14em;text-transform:uppercase;color:var(--danger)\">The ask</div><div style=\"font-size:44px;font-weight:700;margin:20px 0 16px;line-height:1.1\">A user asks something the UI can’t serve</div><div style=\"font-size:29px;color:var(--muted);line-height:1.42\">“Why did <b>my</b> order fail?” — the reason is in the backend logs, not on any button. No skill fires.</div></div><div class=\"fp-fade\" style=\"align-self:center;font-size:56px;color:var(--yellow);font-weight:700\">→</div><div class=\"fp-pop\" style=\"flex:1;border:2px solid var(--line2);border-left:6px solid var(--yellow);border-radius:22px;padding:40px 38px;background:var(--surface)\"><div style=\"font-family:var(--mono);font-size:24px;letter-spacing:.14em;text-transform:uppercase;color:var(--yellow)\">The gap ledger</div><div style=\"font-size:44px;font-weight:700;margin:20px 0 16px;line-height:1.1\">The runtime files a gap</div><div style=\"font-size:29px;color:var(--muted);line-height:1.42\">A token-lean row: the ask, the you-are-here position, what <i>was</i> available. <code style=\"font-family:var(--mono);font-size:.82em;color:var(--yellow-ink)\">session.onGap(…)</code> streams it to your telemetry.</div></div><div></div><div style=\"flex:1\"></div></div><div style=\"text-align:center\"><div style=\"min-height:82px;margin-top:52px\"></div></div></section>"},{"label":"Gap 3","html":"<section data-label=\"Gap 3\" style=\"background:var(--bg);color:var(--text);width:1920px;height:1080px;box-sizing:border-box;display:flex;flex-direction:column;justify-content:center;padding:0 190px;font-family:var(--sans)\"><p style=\"font-family:var(--mono);font-size:29px;letter-spacing:.2em;text-transform:uppercase;color:var(--yellow);margin:0 0 34px\">The gap loop — the point of the thing</p><h2 style=\"font-size:78px;font-weight:700;letter-spacing:-.02em;line-height:1.05;margin:0 0 60px\">When no skill serves the ask, that’s the signal.</h2><div style=\"display:flex;gap:0;align-items:stretch\"><div class=\"fp-enter\" style=\"flex:1;border:2px solid var(--line2);border-left:6px solid var(--danger);border-radius:22px;padding:40px 38px;background:var(--surface)\"><div style=\"font-family:var(--mono);font-size:24px;letter-spacing:.14em;text-transform:uppercase;color:var(--danger)\">The ask</div><div style=\"font-size:44px;font-weight:700;margin:20px 0 16px;line-height:1.1\">A user asks something the UI can’t serve</div><div style=\"font-size:29px;color:var(--muted);line-height:1.42\">“Why did <b>my</b> order fail?” — the reason is in the backend logs, not on any button. No skill fires.</div></div><div class=\"fp-fade\" style=\"align-self:center;font-size:56px;color:var(--yellow);font-weight:700\">→</div><div class=\"fp-pop\" style=\"flex:1;border:2px solid var(--line2);border-left:6px solid var(--yellow);border-radius:22px;padding:40px 38px;background:var(--surface)\"><div style=\"font-family:var(--mono);font-size:24px;letter-spacing:.14em;text-transform:uppercase;color:var(--yellow)\">The gap ledger</div><div style=\"font-size:44px;font-weight:700;margin:20px 0 16px;line-height:1.1\">The runtime files a gap</div><div style=\"font-size:29px;color:var(--muted);line-height:1.42\">A token-lean row: the ask, the you-are-here position, what <i>was</i> available. <code style=\"font-family:var(--mono);font-size:.82em;color:var(--yellow-ink)\">session.onGap(…)</code> streams it to your telemetry.</div></div><div class=\"fp-fade\" style=\"align-self:center;font-size:56px;color:var(--yellow);font-weight:700\">→</div><div class=\"fp-panel\" style=\"flex:1;border:2px solid var(--line2);border-left:6px solid var(--mcp);border-radius:22px;padding:40px 38px;background:var(--surface)\"><div style=\"font-family:var(--mono);font-size:24px;letter-spacing:.14em;text-transform:uppercase;color:var(--mcp)\">You build it</div><div style=\"font-size:44px;font-weight:700;margin:20px 0 16px;line-height:1.1\">Demand-driven backlog</div><div style=\"font-size:29px;color:var(--muted);line-height:1.42\">Cluster the rows and you know exactly what to ship next — a small report, or a tool that reads the failure reason. You locate the missing data, you don’t guess features.</div></div></div><div style=\"text-align:center\"><div class=\"fp-chip\" style=\"margin:52px auto 0;display:inline-flex;align-items:center;gap:16px;font-family:var(--mono);font-size:30px;color:var(--yellow);border:1px solid var(--line2);border-radius:999px;padding:16px 34px\">↻&nbsp; your app grows around <b style=\"color:var(--text);font-weight:600\">real agent demand</b></div></div></section>"},{"label":"Coexist 1","html":"<section data-label=\"Coexist 1\" style=\"background:var(--bg);color:var(--text);width:1920px;height:1080px;box-sizing:border-box;display:flex;flex-direction:column;justify-content:center;padding:0 190px;font-family:var(--sans)\"><p style=\"font-family:var(--mono);font-size:29px;letter-spacing:.2em;text-transform:uppercase;color:var(--yellow);margin:0 0 34px\">Coexists with Anthropic’s MCP</p><h2 style=\"font-size:78px;font-weight:700;letter-spacing:-.02em;line-height:1.05;margin:0 0 70px\">One live session. Any MCP host.</h2><div style=\"display:grid;grid-template-columns:1fr 78px 1fr 78px 1fr 78px 1fr;align-items:stretch;gap:0\"><div class=\"fp-pop\" style=\"border:3px solid var(--app);border-radius:26px;padding:36px 30px;background:color-mix(in srgb, var(--app) 12%, transparent);min-height:230px;display:flex;flex-direction:column;justify-content:center;text-align:center\"><div style=\"font-size:38px;font-weight:700;color:var(--app);line-height:1.12\">Your app</div><div style=\"font-size:25px;color:var(--muted);margin-top:14px;line-height:1.35\">buttons · handlers · router</div></div><div></div><div></div><div></div><div></div><div></div><div></div></div><p style=\"min-height:56px;font-size:34px;color:var(--muted);margin:64px 0 0;text-align:center\">Start with the app a human already drives.</p></section>"},{"label":"Coexist 2","html":"<section data-label=\"Coexist 2\" style=\"background:var(--bg);color:var(--text);width:1920px;height:1080px;box-sizing:border-box;display:flex;flex-direction:column;justify-content:center;padding:0 190px;font-family:var(--sans)\"><p style=\"font-family:var(--mono);font-size:29px;letter-spacing:.2em;text-transform:uppercase;color:var(--yellow);margin:0 0 34px\">Coexists with Anthropic’s MCP</p><h2 style=\"font-size:78px;font-weight:700;letter-spacing:-.02em;line-height:1.05;margin:0 0 70px\">One live session. Any MCP host.</h2><div style=\"display:grid;grid-template-columns:1fr 78px 1fr 78px 1fr 78px 1fr;align-items:stretch;gap:0\"><div class=\"fp-pop\" style=\"border:3px solid var(--app);border-radius:26px;padding:36px 30px;background:color-mix(in srgb, var(--app) 12%, transparent);min-height:230px;display:flex;flex-direction:column;justify-content:center;text-align:center\"><div style=\"font-size:38px;font-weight:700;color:var(--app);line-height:1.12\">Your app</div><div style=\"font-size:25px;color:var(--muted);margin-top:14px;line-height:1.35\">buttons · handlers · router</div></div><div class=\"fp-fade\" style=\"display:flex;align-items:center;justify-content:center;font-size:52px;color:var(--yellow);font-weight:700\">⇄</div><div class=\"fp-pop\" style=\"border:3px solid var(--graph);border-radius:26px;padding:36px 30px;background:color-mix(in srgb, var(--graph) 12%, transparent);min-height:230px;display:flex;flex-direction:column;justify-content:center;text-align:center\"><div style=\"font-size:38px;font-weight:700;color:var(--graph);line-height:1.12\">hcifootprint<br>skill graph</div><div style=\"font-size:25px;color:var(--muted);margin-top:14px;line-height:1.35\">one InteractionSession</div></div><div></div><div></div><div></div><div></div></div><p style=\"min-height:56px;font-size:34px;color:var(--muted);margin:64px 0 0;text-align:center\">Describe its surface once — the skill graph rides on top, zero new backend.</p></section>"},{"label":"Coexist 3","html":"<section data-label=\"Coexist 3\" style=\"background:var(--bg);color:var(--text);width:1920px;height:1080px;box-sizing:border-box;display:flex;flex-direction:column;justify-content:center;padding:0 190px;font-family:var(--sans)\"><p style=\"font-family:var(--mono);font-size:29px;letter-spacing:.2em;text-transform:uppercase;color:var(--yellow);margin:0 0 34px\">Coexists with Anthropic’s MCP</p><h2 style=\"font-size:78px;font-weight:700;letter-spacing:-.02em;line-height:1.05;margin:0 0 70px\">One live session. Any MCP host.</h2><div style=\"display:grid;grid-template-columns:1fr 78px 1fr 78px 1fr 78px 1fr;align-items:stretch;gap:0\"><div class=\"fp-pop\" style=\"border:3px solid var(--app);border-radius:26px;padding:36px 30px;background:color-mix(in srgb, var(--app) 12%, transparent);min-height:230px;display:flex;flex-direction:column;justify-content:center;text-align:center\"><div style=\"font-size:38px;font-weight:700;color:var(--app);line-height:1.12\">Your app</div><div style=\"font-size:25px;color:var(--muted);margin-top:14px;line-height:1.35\">buttons · handlers · router</div></div><div class=\"fp-fade\" style=\"display:flex;align-items:center;justify-content:center;font-size:52px;color:var(--yellow);font-weight:700\">⇄</div><div class=\"fp-pop\" style=\"border:3px solid var(--graph);border-radius:26px;padding:36px 30px;background:color-mix(in srgb, var(--graph) 12%, transparent);min-height:230px;display:flex;flex-direction:column;justify-content:center;text-align:center\"><div style=\"font-size:38px;font-weight:700;color:var(--graph);line-height:1.12\">hcifootprint<br>skill graph</div><div style=\"font-size:25px;color:var(--muted);margin-top:14px;line-height:1.35\">one InteractionSession</div></div><div class=\"fp-fade\" style=\"display:flex;align-items:center;justify-content:center;font-size:52px;color:var(--yellow);font-weight:700\">⇄</div><div class=\"fp-pop\" style=\"border:3px solid var(--mcp);border-radius:26px;padding:36px 30px;background:color-mix(in srgb, var(--mcp) 12%, transparent);min-height:230px;display:flex;flex-direction:column;justify-content:center;text-align:center\"><div style=\"font-size:38px;font-weight:700;color:var(--mcp);line-height:1.12\">MCP server</div><div style=\"font-size:25px;color:var(--muted);margin-top:14px;line-height:1.35\">mcpServer(session)</div></div><div></div><div></div></div><p style=\"min-height:56px;font-size:34px;color:var(--muted);margin:64px 0 0;text-align:center\">The same graph <b>serves as a real MCP server</b> — <code style=\"font-family:var(--mono);font-size:.82em;color:var(--yellow-ink)\">tools/list</code> + <code style=\"font-family:var(--mono);font-size:.82em;color:var(--yellow-ink)\">tools/call</code>.</p></section>"},{"label":"Coexist 4","html":"<section data-label=\"Coexist 4\" style=\"background:var(--bg);color:var(--text);width:1920px;height:1080px;box-sizing:border-box;display:flex;flex-direction:column;justify-content:center;padding:0 190px;font-family:var(--sans)\"><p style=\"font-family:var(--mono);font-size:29px;letter-spacing:.2em;text-transform:uppercase;color:var(--yellow);margin:0 0 34px\">Coexists with Anthropic’s MCP</p><h2 style=\"font-size:78px;font-weight:700;letter-spacing:-.02em;line-height:1.05;margin:0 0 70px\">One live session. Any MCP host.</h2><div style=\"display:grid;grid-template-columns:1fr 78px 1fr 78px 1fr 78px 1fr;align-items:stretch;gap:0\"><div class=\"fp-pop\" style=\"border:3px solid var(--app);border-radius:26px;padding:36px 30px;background:color-mix(in srgb, var(--app) 12%, transparent);min-height:230px;display:flex;flex-direction:column;justify-content:center;text-align:center\"><div style=\"font-size:38px;font-weight:700;color:var(--app);line-height:1.12\">Your app</div><div style=\"font-size:25px;color:var(--muted);margin-top:14px;line-height:1.35\">buttons · handlers · router</div></div><div class=\"fp-fade\" style=\"display:flex;align-items:center;justify-content:center;font-size:52px;color:var(--yellow);font-weight:700\">⇄</div><div class=\"fp-pop\" style=\"border:3px solid var(--graph);border-radius:26px;padding:36px 30px;background:color-mix(in srgb, var(--graph) 12%, transparent);min-height:230px;display:flex;flex-direction:column;justify-content:center;text-align:center\"><div style=\"font-size:38px;font-weight:700;color:var(--graph);line-height:1.12\">hcifootprint<br>skill graph</div><div style=\"font-size:25px;color:var(--muted);margin-top:14px;line-height:1.35\">one InteractionSession</div></div><div class=\"fp-fade\" style=\"display:flex;align-items:center;justify-content:center;font-size:52px;color:var(--yellow);font-weight:700\">⇄</div><div class=\"fp-pop\" style=\"border:3px solid var(--mcp);border-radius:26px;padding:36px 30px;background:color-mix(in srgb, var(--mcp) 12%, transparent);min-height:230px;display:flex;flex-direction:column;justify-content:center;text-align:center\"><div style=\"font-size:38px;font-weight:700;color:var(--mcp);line-height:1.12\">MCP server</div><div style=\"font-size:25px;color:var(--muted);margin-top:14px;line-height:1.35\">mcpServer(session)</div></div><div class=\"fp-fade\" style=\"display:flex;align-items:center;justify-content:center;font-size:52px;color:var(--yellow);font-weight:700\">⇄</div><div class=\"fp-pop\" style=\"border:3px solid var(--host);border-radius:26px;padding:36px 30px;background:color-mix(in srgb, var(--host) 12%, transparent);min-height:230px;display:flex;flex-direction:column;justify-content:center;text-align:center\"><div style=\"font-size:38px;font-weight:700;color:var(--host);line-height:1.12\">Any MCP host</div><div style=\"font-size:25px;color:var(--muted);margin-top:14px;line-height:1.35\">Claude Desktop · LangGraph · raw loop</div></div></div><p style=\"min-height:56px;font-size:34px;color:var(--muted);margin:64px 0 0;text-align:center\">Any MCP host drives the same live session — the human and the agent, a team on one screen.</p></section>"},{"label":"Stays true","html":"<section data-label=\"Stays true\" style=\"background:var(--bg);color:var(--text);width:1920px;height:1080px;box-sizing:border-box;display:flex;flex-direction:column;justify-content:center;padding:0 190px;font-family:var(--sans)\"><p style=\"font-family:var(--mono);font-size:29px;letter-spacing:.2em;text-transform:uppercase;color:var(--yellow);margin:0 0 34px\">Stays true</p><h2 style=\"font-size:82px;font-weight:700;letter-spacing:-.02em;line-height:1.05;margin:0 0 22px\">The graph is a second artifact.<br>So catch the drift.</h2><p style=\"font-size:34px;color:var(--muted);margin:0 0 54px;max-width:40ch;line-height:1.4\"><code style=\"font-family:var(--mono);font-size:.85em;color:var(--yellow-ink)\">hcifootprint/testing</code> drives the <b style=\"color:var(--text)\">real</b> session — zero new deps — so you release knowing the graph still matches the app.</p><div style=\"display:flex;gap:34px\"><div style=\"flex:1;border:2px solid var(--line2);border-top:6px solid var(--mcp);border-radius:20px;padding:38px 34px;background:var(--surface)\"><div style=\"font-family:var(--mono);font-size:40px;font-weight:600;color:var(--mcp)\">lintGraph</div><div style=\"font-size:28px;color:var(--muted);margin-top:20px;line-height:1.42\">Static, no test code. Flags stale logic from the graph alone — the cheap CI gate.</div></div><div style=\"flex:1;border:2px solid var(--line2);border-top:6px solid var(--app);border-radius:20px;padding:38px 34px;background:var(--surface)\"><div style=\"font-family:var(--mono);font-size:40px;font-weight:600;color:var(--app)\">testApp</div><div style=\"font-size:28px;color:var(--muted);margin-top:20px;line-height:1.42\">Playwright for your interaction logic, minus the browser. <code style=\"font-family:var(--mono);font-size:.8em;color:var(--yellow-ink)\">effectVerified</code> flips false on behavioral drift.</div></div><div style=\"flex:1;border:2px solid var(--line2);border-top:6px solid var(--host);border-radius:20px;padding:38px 34px;background:var(--surface)\"><div style=\"font-family:var(--mono);font-size:40px;font-weight:600;color:var(--host)\">checkGraph</div><div style=\"font-size:28px;color:var(--muted);margin-top:20px;line-height:1.42\">One-call health verdict — findings grouped by drift type + a printable report.</div></div></div><div class=\"fp-chip\" style=\"margin-top:46px;font-family:var(--mono);font-size:27px;color:var(--muted)\">honest by construction · <span style=\"color:var(--yellow-ink)\">activation:'assumed'</span> · <span style=\"color:var(--yellow-ink)\">presence:'unknown'</span> · typed refusals</div></section>"},{"label":"Close","html":"<section data-label=\"Close\" style=\"background:var(--bg);color:var(--text);width:1920px;height:1080px;box-sizing:border-box;display:flex;flex-direction:column;justify-content:center;padding:0 190px;font-family:var(--sans);align-items:center;text-align:center\"><h2 style=\"font-size:118px;font-weight:700;letter-spacing:-.03em;margin:0;line-height:1.04\">author → connect → serve</h2><div style=\"margin:58px auto 0;font-family:var(--mono);font-size:40px;color:var(--yellow);border:1px solid var(--line2);border-radius:16px;padding:26px 44px;background:var(--surface)\">npm install hcifootprint</div><p style=\"font-family:var(--mono);font-size:30px;color:var(--muted);margin-top:60px\">GitHub · npm · dress-shop demo · the debugger</p><p style=\"font-size:28px;color:var(--faint);margin-top:34px\">open source · MIT · a footprintjs library</p></section>"}]}