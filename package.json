{
  "name": "hcifootprint",
  "version": "0.1.0",
  "description": "Turn a web app's interaction surface into a typed, traversable skill graph an LLM can plan over — the frontend sibling of footprintjs.",
  "homepage": "https://footprintjs.github.io/hcifootprint/",
  "repository": { "type": "git", "url": "git+https://github.com/footprintjs/hcifootprint.git" },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./mcp": {
      "types": "./dist/mcp.d.ts",
      "default": "./dist/mcp.js"
    },
    "./testing": {
      "types": "./dist/testing/index.d.ts",
      "default": "./dist/testing/index.js"
    },
    "./testing/lint": {
      "types": "./dist/testing/lint.d.ts",
      "default": "./dist/testing/lint.js"
    }
  },
  "files": [
    "dist/**/*",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "rm -rf dist && tsc",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.test.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "demo:chat": "tsx examples/dress-shop/chatbot.ts"
  },
  "keywords": [
    "llm",
    "agent",
    "mcp",
    "skill-graph",
    "affordance",
    "interaction-graph",
    "footprintjs"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "footprintjs": "file:../footPrint"
  },
  "peerDependencies": {
    "@modelcontextprotocol/sdk": ">=1.0.0"
  },
  "peerDependenciesMeta": {
    "@modelcontextprotocol/sdk": {
      "optional": true
    }
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.110.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/node": "^20.0.0",
    "tsx": "^4.22.5",
    "typescript": "^5.5.0",
    "vitest": "^4.0.0",
    "zod": "^4.0.0"
  }
}
